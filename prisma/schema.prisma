generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String   @id @default(uuid())
  name          String
  industry      String?
  employeeCount Int?
  createdAt     DateTime @default(now())

  departments   Department[]
  employees     Employee[]
  importRuns    ImportRun[]
  surveys       Survey[]

  @@index([name])
}

model Department {
  id        String   @id @default(uuid())
  name      String
  companyId String
  parentId  String?

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]
  metrics   TeamMetricsMonthly[]

  @@index([companyId])
  @@index([parentId])
  @@unique([companyId, name])
}

model Employee {
  id              String   @id @default(uuid())
  companyId       String
  departmentId    String?
  managerId       String?
  externalCode    String?
  firstName       String?
  lastName        String?
  hireDate        DateTime
  terminationDate DateTime?
  jobTitle        String?
  jobLevel        String?
  contractType    String?
  location        String?
  workMode        String?
  ageBand         String?
  gender          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager         Employee?          @relation("ManagerRelation", fields: [managerId], references: [id], onDelete: SetNull)
  reports         Employee[]         @relation("ManagerRelation")
  absences        Absence[]
  performance     PerformanceReview[]
  surveyResponses SurveyResponse[]
  promotions      Promotion[]
  riskScores      EmployeeRiskScore[]

  @@index([companyId])
  @@index([departmentId])
  @@index([managerId])
  @@index([externalCode])
}

model Absence {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime
  days       Int
  type       String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
}

model Promotion {
  id          String   @id @default(uuid())
  employeeId  String
  effectiveAt DateTime
  oldLevel    String?
  newLevel    String?

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveAt])
}

model PerformanceReview {
  id         String   @id @default(uuid())
  employeeId String
  reviewDate DateTime
  score      Float
  reviewer   String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([reviewDate])
}

model Survey {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@index([companyId])
  @@index([createdAt])
}

model SurveyResponse {
  id         String   @id @default(uuid())
  surveyId   String
  employeeId String
  dimension  String
  score      Float

  survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([employeeId])
  @@index([dimension])
}

model EmployeeRiskScore {
  id            String   @id @default(uuid())
  employeeId    String
  scoringDate   DateTime
  attritionRisk Float
  burnoutRisk   Float
  driver1       String?
  driver2       String?
  driver3       String?

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([scoringDate])
  @@unique([employeeId, scoringDate])
}

model TeamMetricsMonthly {
  id               String   @id @default(uuid())
  departmentId     String
  month            DateTime
  headcount        Int
  turnoverRate     Float
  absenteeismRate  Float
  engagementScore  Float
  burnoutRiskAvg   Float
  attritionRiskAvg Float

  department       Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([month])
  @@unique([departmentId, month])
}

model ImportRun {
  id                  String           @id @default(uuid())
  companyId           String?
  companyNameSnapshot String?
  dataset             String
  fileName            String
  fileType            String
  status              String
  hasHeader           Boolean
  totalRows           Int
  importedCount       Int?
  createdCount        Int?
  updatedCount        Int?
  issueCount          Int              @default(0)
  errorMessage        String?
  createdAt           DateTime         @default(now())

  company             Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  issues              ImportRunIssue[]

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([dataset, createdAt])
}

model ImportRunIssue {
  id        String    @id @default(uuid())
  runId     String
  rowNumber Int
  field     String
  message   String

  run       ImportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}
